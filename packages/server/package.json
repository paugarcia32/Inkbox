{
  "name": "@hako/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "pnpm --filter @hako/db db:migrate",
    "db:push": "pnpm --filter @hako/db db:push",
    "db:studio": "pnpm --filter @hako/db db:studio",
    "db:migrate:test": "pnpm --filter @hako/db db:migrate:test"
  },
  "dependencies": {
    "@hako/db": "workspace:*",
    "@hako/trpc": "workspace:*",
    "@hono/node-server": "^1.0.0",
    "@hono/trpc-server": "^0.3.4",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.0.0",
    "hono": "^4.0.0",
    "ioredis": "^5.4.0",
    "rate-limiter-flexible": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hako/shared": "workspace:*",
    "@types/node": "^22.0.0",
    "dotenv-cli": "^11.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
