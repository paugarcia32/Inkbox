{
  "name": "@hako/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate",
    "db:migrate": "dotenv -e ../../apps/api/.env -- prisma migrate dev",
    "db:push": "dotenv -e ../../apps/api/.env -- prisma db push",
    "db:studio": "dotenv -e ../../apps/api/.env -- prisma studio",
    "db:migrate:test": "dotenv -e ../../apps/api/.env.test -- prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "@hako/config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
