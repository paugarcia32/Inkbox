{
  "name": "@hako/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "typecheck": "tsc --noEmit",
    "db:migrate": "pnpm --filter @hako/db db:migrate",
    "db:push": "pnpm --filter @hako/db db:push",
    "db:studio": "pnpm --filter @hako/db db:studio",
    "db:migrate:test": "pnpm --filter @hako/db db:migrate:test"
  },
  "dependencies": {
    "@hako/db": "workspace:*",
    "@hako/trpc": "workspace:*",
    "@hako/types": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.0.0",
    "reflect-metadata": "^0.2.0",
    "rate-limiter-flexible": "^5.0.0",
    "rxjs": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@hako/config": "workspace:*",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@swc/core": "^1.15.18",
    "@swc/helpers": "^0.5.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.0"
  }
